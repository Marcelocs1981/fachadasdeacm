---
import '../styles/header.css';
---

<header class="header">
  <div class="header-container">

    <a href="/" class="logo">
      <img src="/fachadas-de-acm-logo.png" alt="Fachadas em ACM" width="144" height="88" loading="eager" decoding="async"/>
    </a>

    <!-- CHECKBOX (OBRIGATÓRIO VIR ANTES DO MENU) -->
    <input type="checkbox" id="menu-toggle" />

    <!-- BOTÃO HAMBURGUER -->
    <label for="menu-toggle" class="menu-icon">☰</label>

    <!-- MENU -->
    <nav class="nav">
      <a href="/">Home</a>
      <a href="/empresa">Empresa</a>
      <a href="/servicos">Serviços</a>
      <a href="/contato">Contato</a>
      <a href="/blog">Blog</a>
    </nav>

    <!-- CTA -->
    <a href="#" class="cta">Orçamento</a>

  </div>
</header>